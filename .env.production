# Database Configuration
DATABASE_URL=postgresql://aeroledger:your_password@localhost:5432/aeroledger

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Server Configuration
HOST=127.0.0.1
PORT=8080
RUST_LOG=info

# Wallet Addresses (Replace with your actual addresses)
WALLET_ADDRESS_BTC=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
WALLET_ADDRESS_ETH=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
WALLET_ADDRESS_SOL=DYw8jCTfwHNRJhhmFcbXvVDTqWMEVFBX6ZKUmG5CNSKK
WALLET_ADDRESS_USDT=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
